<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
	<id>@APP_ID@</id>
	<project_license>GPL-3.0-or-later</project_license>
	<metadata_license>FSFAP</metadata_license>
	<!-- Translators: The name of the application. -->
	<name>Field Monitor</name>
	<!-- Translators: The summary of the application in the metainfo. -->
	<summary>Access VMs and external screens</summary>
	<launchable type="desktop-id">@APP_ID@.desktop</launchable>
	<content_rating type="oars-1.1"/>
	<developer id="de.capypara">
		<name translate="no">Marco Köpcke</name>
	</developer>
	<translation type="gettext">@APP_ID@</translation>

	<categories>
		<category>Utility</category>
		<category>Network</category>
	</categories>

	<keywords>
		<!-- Translators: Keyword in the metainfo. -->
		<keyword>remote desktop</keyword>
		<!-- Translators: Keyword in the metainfo. -->
		<keyword>RDP</keyword>
		<!-- Translators: Keyword in the metainfo. -->
		<keyword>VNC</keyword>
		<!-- Translators: Keyword in the metainfo. -->
		<keyword>SPICE</keyword>
		<!-- Translators: Keyword in the metainfo. -->
		<keyword>KVM</keyword>
		<!-- Translators: Keyword in the metainfo. -->
		<keyword>QEMU</keyword>
		<!-- Translators: Keyword in the metainfo. -->
		<keyword>libvirt</keyword>
		<!-- Translators: Keyword in the metainfo. -->
		<keyword>Proxmox</keyword>
		<!-- Translators: Keyword in the metainfo. -->
		<keyword>GNOME</keyword>
	</keywords>

	<url type="homepage">https://github.com/theCapypara/field-monitor</url>
	<url type="bugtracker">https://github.com/theCapypara/field-monitor/issues</url>
	<url type="vcs-browser">https://github.com/theCapypara/field-monitor</url>

	<description>
		<!-- Translators: Part of the description of the application in the metainfo. -->
		<p>
			Field Monitor is a remote-desktop client designed for the GNOME platform.
		</p>
		<!-- Translators: Part of the description of the application in the metainfo. -->
		<p>
			It is focused on connecting to virtual machines, but can connect to any server
			supporting the RDP, SPICE or VNC protocols.
		</p>
		<!-- Translators: Part of the description of the application in the metainfo. -->
		<p>
			It has support for directly connecting to VMs of the following hypervisors:
		</p>
		<ul>
			<li>Proxmox Virtual Environment</li>
			<!-- Translators: Part of the description of the application in the metainfo. -->
			<li>QEMU/KVM via libvirt (including GNOME Boxes VMs)</li>
		</ul>
		<!-- Translators: Part of the description of the application in the metainfo. -->
		<p>
			For supported VM hypervisors Field Monitor also offers options to manage the basic
			power state of VMs, such as starting, stopping, rebooting, etc.
		</p>
		<!-- Translators: Part of the description of the application in the metainfo. -->
		<p>
			Additionally, Field Monitor supports opening RDP and Virt Viewer connection files
			and quickly connecting to RDP, SPICE or VNC servers via URI.
		</p>
	</description>

	<releases>
		<release version="50.0" date="2026-04-29">
			<description translate="no">
				<p>This release updates Field Monitor for GNOME 50 and adds several major new features.</p>
				<ul>
					<li>Multiple monitors are now supported for SPICE connections.</li>
					<li>SPICE connections now support sharing USB devices. This is implemented via the XDG USB Portal
						and requires your desktop to support it and your user to have write permissions to devices.
					</li>
					<li>TLS certificates are now verified - if a certificate is unknown, you are asked to confirm your
						trust.
					</li>
					<li>libvirt SPICE connections can now use local sockets and file descriptors when available and
						support GPU accelerated rendering for those, if enabled on the VM.
					</li>
					<li>Proxmox connections automatically add the "@pam" realm for the username, when no realm is
						specified.
					</li>
					<li>Improved RDP performance, fixed RDP mouse scroll speed, and fixed pasting of Unicode text into
						RDP sessions.
					</li>
					<li>Fixed several SPICE cursor issues (hot-spot alignment, restoring after being hidden).
					</li>
					<li>Fixed a crash when repeatedly trying to move views into new windows.</li>
					<li>Added Spanish translations (thanks to Óscar Fernández Díaz).</li>
					<li>German translation has been updated.</li>
					<li>All libraries used by Field Monitor have been updated.</li>
				</ul>
			</description>
		</release>
		<release version="49.1" date="2025-11-23">
			<description translate="no">
				<p>This release brings some small improvements.</p>
				<ul>
					<li>RDP connections to Windows servers no longer have swapped color channels.</li>
					<li>Pasting text into RDP connections to Windows servers no longer cuts off the last character in
						some cases.
					</li>
					<li>The app now requires less permissions when installed via Flatpak.</li>
					<li>Dialogs can now be accepted using the ENTER key when inside of text input fields (thanks to
						f1ori).
					</li>
					<li>Added context menus in the sidebar.</li>
					<li>Servers in a generic connection group can now be edited individually right from the server list
						using a new edit button.
					</li>
					<li>Fixed one of the "Keyboard Shortcuts" menu items not working.</li>
					<li>Small wording changes.</li>
				</ul>
			</description>
		</release>
		<release version="49.0" date="2025-11-06">
			<description translate="no">
				<p>This release updates Field Monitor for GNOME 49.</p>
				<ul>
					<li>All libraries used by Field Monitor have been updated to the latest version.</li>
					<li>
						RDP connections are now handled with IronRDP instead of FreeRDP 2.
						This is a more secure and modern implementation and should fix some issues, however IronRDP
						is still overall less compatible with some RDP server implementations.
					</li>
					<li>Fixed the cursor sometimes disappearing on SPICE connections.</li>
					<li>Changed the icon for the main menu to be the same as other GNOME apps (thanks to rdbende).</li>
					<li>Added Brazilian Portuguese translations (thanks to Cybercountry).</li>
					<li>Added Russian translations (thanks to vmkspv).</li>
					<li>Minor design changes to the navbar and adapted new shortcut dialog.</li>
					<li>Improved app startup performance and error handling.</li>
				</ul>
			</description>
		</release>
		<release version="48.0" date="2025-03-24">
			<description translate="no">
				<p>Initial Release.</p>
			</description>
		</release>
	</releases>

