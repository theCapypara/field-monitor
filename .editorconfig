root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space

#[*.rs]
#indent_size = 4 - this is disabled because of some false positives; use `cargo fmt`

[*.nix]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{xml,xml.in,xml.in.in,doap}]
indent_style = tab
